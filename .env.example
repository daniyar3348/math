# ——— БД (docker compose up -d поднимает Postgres на 5433) ———
DATABASE_URL="postgresql://bilimhub:bilimhub_dev@localhost:5433/bilimhub"
# Отдельная схема для integration-тестов (тот же инстанс)
DATABASE_URL_TEST="postgresql://bilimhub:bilimhub_dev@localhost:5433/bilimhub?schema=test"

# ——— Безопасность ———
# Секрет для подписи файловых URL и служебных токенов (в production — длинный случайный)
APP_SECRET="dev-secret-change-me"

# ——— SMS (OTP входа учеников) ———
# dev = код печатается в консоль сервера и возвращается в ответе (только не в production)
SMS_PROVIDER="dev"
# Пример боевого подключения (реализуется провайдером в lib/auth/sms.ts):
# SMS_PROVIDER="http"
# SMS_HTTP_URL="https://sms-gateway.example/send"
# SMS_HTTP_TOKEN="…"

# ——— Файлы ———
FILE_STORAGE="disk"          # disk | s3 (S3/MinIO подключается без изменения кода)
UPLOADS_DIR="uploads"
# S3_ENDPOINT=…  S3_BUCKET=…  S3_ACCESS_KEY=…  S3_SECRET_KEY=…

# ——— Платежи ———
PAYMENT_PROVIDER="mock"      # mock | (реальный провайдер добавляется через интерфейс)

# ——— Прочее ———
TZ="Asia/Almaty"
