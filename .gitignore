# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (примеры без секретов — коммитятся)
.env*
!.env.example
!.env.docker.example

# сгенерированный Prisma-клиент (создаётся postinstall'ом)
/lib/generated

# артефакты тестов
/test-results
/playwright-report

# загрузки пользователей
/uploads

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
