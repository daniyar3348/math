# Окружение контейнера app (docker compose --profile app).
# Скопируйте в .env.docker и задайте собственные значения — файл с реальными
# секретами в репозиторий не коммитится.

# db — имя сервиса compose; внутри сети порт стандартный 5432
DATABASE_URL="postgresql://bilimhub:CHANGE_ME_DB_PASSWORD@db:5432/bilimhub"

# Длинная случайная строка (подпись файловых ссылок и webhook'ов)
APP_SECRET="CHANGE_ME_LONG_RANDOM"

# SMS: в production только реальный шлюз
SMS_PROVIDER="http"
SMS_HTTP_URL=""
SMS_HTTP_TOKEN=""

# Платежи: mock до подключения реального провайдера
PAYMENT_PROVIDER="mock"

FILE_STORAGE="disk"
UPLOADS_DIR="/app/uploads"
TZ="Asia/Almaty"
